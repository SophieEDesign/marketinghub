# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key: server-side only (user management, admin operations). Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (optional; used for redirects; defaults to localhost:3000 in dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Rate limiting (optional): when set, /api/users/invite limited to 5/15min per IP
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token

# Cron auth (required in production): bearer token for /api/automations/run-scheduled
# CRON_SECRET=your-random-secret

# Email (server-only): mention notifications and automation send_email actions
# RESEND_API_KEY=re_xxxxxxxx

# Development only: skip auth checks. Never enable in production.
# AUTH_BYPASS=true

# Optional: PostgREST row limit override if your server uses a different default (e.g. 21)
# POSTGREST_DEFAULT_MAX_ROWS=2000

# Optional: enable debug telemetry to local ingest (127.0.0.1). Leave unset in production.
# NEXT_PUBLIC_DEBUG_TELEMETRY=1

# Google Drive gallery (server-only; service account must have Viewer on the gallery folder)
# Option A — separate vars:
# GOOGLE_SERVICE_ACCOUNT_EMAIL=...@...iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Option B — paste the full service-account JSON (often easiest on Vercel):
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...@...iam.gserviceaccount.com",...}
# DRIVE_GALLERY_ROOT_FOLDER_ID=your-root-folder-id
