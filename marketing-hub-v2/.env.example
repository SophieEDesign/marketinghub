# Local / preview demo (never enable on Vercel Production)
AUTH_BYPASS=true
NEXT_PUBLIC_AUTH_BYPASS=true

# App URL (required for invite / password-reset email redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Supabase (required in production — turn AUTH_BYPASS off)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Drive gallery (optional)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Or:
# GOOGLE_SERVICE_ACCOUNT_EMAIL=...@....iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# DRIVE_GALLERY_ROOT_FOLDER_ID=your-root-folder-id

# Planable (optional)
# PLANABLE_API_TOKEN=your-token
# PLANABLE_WORKSPACE_ID=your-workspace-id
# PLANABLE_APP_URL=https://app.planable.io

# Core Data import mapping (see DATA_SOURCES.md):
#   Events module  ← dedicated Events table
#   Content module ← Social Posts table
#   Legacy Content table is ignored

# Durable hub store (when service role is set): JSON snapshot in public.hub_store
# Local demo without service role still uses .data/store.json

# Web enquiries webhook (WordPress P&M Quote Builder primary URL)
# Point plugin Settings → Webhook URL (primary) at:
#   https://<hub-domain>/api/enquiries?key=<WEB_ENQUIRY_WEBHOOK_SECRET>
# WEB_ENQUIRY_WEBHOOK_SECRET=generate-a-long-random-secret

# Auto-accept Member on /request-access for these email domains (comma-separated)
# HUB_MEMBER_EMAIL_DOMAINS=petersandmay.com
